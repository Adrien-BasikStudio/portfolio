DirectoryIndex index.html
Options -Indexes

# Annule la regle parent qui redirige tout vers /public/ (Laravel des autres sites du compte)
RewriteEngine On
RewriteRule .* - [L]

# ===== EN-TÊTES DE SÉCURITÉ =====
<IfModule mod_headers.c>
  # Empêche le clickjacking (iframe depuis un autre domaine)
  Header always set X-Frame-Options "SAMEORIGIN"

  # Empêche le sniffing MIME (ex. servir un .jpg comme script)
  Header always set X-Content-Type-Options "nosniff"

  # Réduit les infos envoyées aux sites tiers via Referer
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Désactive l'accès à caméra / micro / géolocalisation
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

  # HSTS : force HTTPS pendant 1 an (à activer une fois le certificat SSL stable)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

  # Content Security Policy
  # - scripts : site + CDN Three.js + Vanta (unsafe-inline nécessaire pour le script inline de thème)
  # - styles  : site + Google Fonts
  # - fonts   : Google Fonts
  # - images  : site + tous les CDN d'icônes
  # - connect : site uniquement (fetch vers projects.json, photos.json, contact.php)
  Header always set Content-Security-Policy "\
    default-src 'self';\
    script-src 'self' 'sha256-wbwocCbN7FUWvErV+/erZ6onzjkYs5SQw7guJ8Fa3Ls=' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net;\
    style-src 'self' 'unsafe-inline' https://fonts.googleapis.com;\
    font-src 'self' https://fonts.gstatic.com;\
    img-src 'self' data: https://cdn.simpleicons.org https://cdn.jsdelivr.net https://unpkg.com;\
    connect-src 'self';\
    frame-ancestors 'none';\
    base-uri 'self';\
    form-action 'self';\
  "
</IfModule>

# ===== CACHE STATIQUE =====
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png  "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 week"
  ExpiresByType text/css   "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
</IfModule>
